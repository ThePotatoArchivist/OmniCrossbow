{
	"schemaVersion": 1,
	"id": "omnicrossbow",
	"version": "${version}",
	"name": "OmniCrossbow",
	"description": "Shoot any item from a crossbow!",
	"authors": [
		"ThePotatoArchivist"
	],
	"contact": {
		"homepage": "https://modrinth.com/project/omni-crossbow",
		"sources": "https://github.com/ThePotatoArchivist/OmniCrossbow/"
	},
	"license": "LGPL-3.0-or-later",
	"icon": "assets/omnicrossbow/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "archives.tater.omnicrossbow.OmniCrossbow",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "archives.tater.omnicrossbow.OmniCrossbowClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "archives.tater.omnicrossbow.OmniCrossbowDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"omnicrossbow.mixins.json",
		{
			"config": "omnicrossbow.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~26.1-",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}